# Copy to .env for your own notes, then export these variables in the shell
# that launches Codex. This project never reads or requests a ChatGPT token.
STEAM_API_KEY=
ITAD_API_KEY=
DEFAULT_REGION=CN
STEAM_PROFILE=
# Optional. Defaults to ~/.steam-deal-agent (or the Windows equivalent).
STEAM_DEAL_AGENT_DATA_DIR=
