{
  "mcpServers": {
    "steam-deal-agent": {
      "command": "node",
      "args": ["./dist/index.js"],
      "cwd": ".",
      "env": {
        "STEAM_API_KEY": "${STEAM_API_KEY}",
        "ITAD_API_KEY": "${ITAD_API_KEY}",
        "DEFAULT_REGION": "${DEFAULT_REGION}",
        "STEAM_PROFILE": "${STEAM_PROFILE}"
      }
    }
  }
}
